# Backend environment when running inside Docker
# Copy to backend/.env in a containerized setup

PORT=4000
NODE_ENV=development
JWT_SECRET=please-change-me
# Connect to Postgres by service name on the compose network
DATABASE_URL=postgres://postgres:postgres@db:5432/room_manager

# Frontend origin for CORS (adjust if frontend runs in Docker)
CORS_ORIGIN=http://localhost:3000

