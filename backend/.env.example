# Backend service environment
# Copy to backend/.env and adjust values

PORT=4000
NODE_ENV=development
## HS256 key must be at least 32 bytes (256 bits)
JWT_SECRET=4c3f3bd13f6e4a6aa3f5c16f2c0d7cc1b2a1d9f84f0a3e5c7b9d2f1a6c4e3b1a

DATABASE_URL=postgres://postgres:postgres@localhost:5432/room_manager

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:3000

# Session cookie name used for JWT
SESSION_COOKIE_NAME=rm_session
