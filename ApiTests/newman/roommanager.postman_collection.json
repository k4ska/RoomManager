	},
	"item": [
		{
			"name": "test_register",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Try to register the test user. If already exists (409), fall back to login to obtain session cookie.",
							"pm.test(\"Register or already exists\", () => pm.expect([201,409]).to.include(pm.response.code));",
							"if (pm.response.code === 201) {",
							"  const setCookie = pm.response.headers.get(\"set-cookie\");",
							"  if (setCookie) {",
							"    const m = setCookie.match(/rm_session=([^;]+)/);",
							"    if (m) pm.environment.set(\"session_token\", m[1]);",
							"  }",
							"} else if (pm.response.code === 409) {",
							"  // User exists: perform login to obtain cookie",
							"  pm.sendRequest({",
							"    url: pm.environment.get(\"url\") + '/api/auth/login',",
							"    method: 'POST',",
							"    header: { 'Content-Type': 'application/json' },",
							"    body: { mode: 'raw', raw: JSON.stringify({ email: 'testuser@example.com', password: 'P@ssw0rd!' }) }",
							"  }, function (err, res) {",
							"    if (err) { console.error(err); return; }",
							"    if (res) {",
							"      const setCookie = res.headers.get('set-cookie');",
							"      if (setCookie) {",
							"        const m = setCookie.match(/rm_session=([^;]+)/);",
							"        if (m) pm.environment.set('session_token', m[1]);",
							"      }",
							"    }",
							"  });",
							"}"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n\"email\": \"testuser@example.com\",\n\"password\": \"P@ssw0rd!\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": "{{url}}/api/auth/register"
			},
			"response": []
		},
		{
			"name": "test_login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 200\", () => pm.response.to.have.status(200));\r",
							"const json = pm.response.json();\r",
							"pm.test(\"ok true\", () => pm.expect(json.ok).to.eql(true));\r",
							"const setCookie = pm.response.headers.get(\"set-cookie\");\r",
							"pm.test(\"set-cookie header present\", () => pm.expect(setCookie).to.match(/rm_session=/));\r",
							"if (setCookie) {\r",
							"const m = setCookie.match(/rm_session=([^;]+)/);\r",
							"if (m) pm.environment.set(\"session_token\", m[1]);\r",
							"}"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n\"email\": \"testuser@example.com\",\r\n\"password\": \"P@ssw0rd!\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": "{{url}}/api/auth/login"
			},
			"response": []
		},
		{
			"name": "test_me",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status is 200\", () => pm.response.to.have.status(200));\r",
							"const json = pm.response.json();\r",
							"pm.test(\"ok true\", () => pm.expect(json.ok).to.eql(true));\r",
							"pm.test(\"user exists\", () => pm.expect(json.user).to.not.eql(null));\r",
							"// optional: check email\r",
							"pm.test(\"email matches\", () => pm.expect(json.user.email).to.eql(\"testuser@example.com\"));"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Cookie",
						"value": "rm_session={{session_token}}",
						"type": "text"
					}
				],
				"url": "{{url}}/api/auth/me"
			},
			"response": []
		},
